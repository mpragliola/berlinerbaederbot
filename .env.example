# API Server Configuration (/api)
API_PORT=3000

# Telegram Bot Configuration (/bot)
BOT_TOKEN=your_telegram_bot_token_here
POOLS_API_URL=http://localhost:3000
DEFAULT_RADIUS_KM=3

# Scraping Configuration
SCRAPE_INTERVAL=3600000
CACHE_TTL=3600000

# Railway Deployment Notes
# - Create separate .env files for each service folder (/api/.env and /bot/.env)
# - In Railway, set BOT_TOKEN and POOLS_API_URL as project variables
# - For internal communication: POOLS_API_URL=http://api:3000
# - For external access: POOLS_API_URL=https://your-api-service.railway.app
