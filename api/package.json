{
  "name": "berliner-baeder-api",
  "version": "1.0.0",
  "description": "API server for Berliner Bäder pool data",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "scrape:catalog": "node scraper-catalog.js",
    "scrape:hours": "node scraper-hours.js",
    "scrape:all": "npm run scrape:catalog && npm run scrape:hours",
    "dev": "nodemon server.js"
